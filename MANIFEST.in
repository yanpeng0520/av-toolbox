include LICENSE
include README.md
include pyproject.toml

graft docs
graft src
graft tests

prune .codex
prune omni-video-pipeline
prune outputs
prune output
prune results
prune testing
prune data_samples
prune multicam_samples
prune models
prune build
prune dist
prune data_segments
prune docs/assets

# Local/private deployment notes (also gitignored).
exclude docs/cloudflare-demo.md
exclude docs/streamlit-demo-overview.md

global-exclude *.gif
global-exclude *.mp4

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
global-exclude *.ckpt
global-exclude *.pt
global-exclude *.pth
global-exclude *.onnx
global-exclude *.safetensors
global-exclude *.h5
